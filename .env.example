# ══════════════════════════════════════════════════════════════
# EduScore Lebanon — Environment Variables
# Copy this file to .env and fill in all required values.
# ══════════════════════════════════════════════════════════════

# ── DATABASE ───────────────────────────────────────────────────
# Production: Neon PostgreSQL connection string
# Get it from: https://neon.tech → Project → Connection string
DATABASE_URL="postgresql://user:password@ep-xxx.neon.tech/eduscore?sslmode=require"

# Neon requires a direct (non-pooled) URL for migrations
DIRECT_URL="postgresql://user:password@ep-xxx.neon.tech/eduscore?sslmode=require"

# ── AUTH ───────────────────────────────────────────────────────
# Required: generate with: openssl rand -base64 32
AUTH_SECRET="your-32-char-secret-here"

# Google OAuth (optional — only needed if Google login is enabled)
AUTH_GOOGLE_ID="your-google-client-id.apps.googleusercontent.com"
AUTH_GOOGLE_SECRET="your-google-client-secret"

# ── APP ────────────────────────────────────────────────────────
# The public URL of your deployed site (no trailing slash)
NEXT_PUBLIC_APP_URL="https://your-project.vercel.app"
NEXT_PUBLIC_APP_NAME="EduScore Lebanon"

# ── CRON SECURITY ──────────────────────────────────────────────
# Protects /api/cron/* endpoints from unauthorized calls.
# Generate with: openssl rand -base64 32
# Also set this as CRON_SECRET in your Vercel project settings.
CRON_SECRET="your-cron-secret-here"

# ── BETA INDEXING CONTROL ──────────────────────────────────────
# Set to "false" when you are ready for full public launch.
# While "true" (or unset), robots.txt blocks all search engines.
BETA_NO_INDEX="true"

# ── REDIS (optional — only needed for BullMQ job queue) ────────
# Leave blank on Vercel (jobs run via cron instead).
# Only needed if you run a separate worker process.
REDIS_URL="redis://localhost:6379"

# ── EMAIL (optional — for seat alert emails) ───────────────────
EMAIL_SERVER_HOST="smtp.gmail.com"
EMAIL_SERVER_PORT="587"
EMAIL_SERVER_USER="your-email@gmail.com"
EMAIL_SERVER_PASSWORD="your-app-password"
EMAIL_FROM="noreply@eduscore.lb"

# ── ANALYTICS (optional) ───────────────────────────────────────
NEXT_PUBLIC_GA_MEASUREMENT_ID="G-XXXXXXXXXX"

# ── ADSENSE (optional) ─────────────────────────────────────────
NEXT_PUBLIC_ADSENSE_CLIENT_ID="ca-pub-xxxxxxxxxxxxxxxxx"

# ── DEV ONLY (never set in production) ─────────────────────────
# DEV_TEST_PASSWORD="test123"
# NEXTAUTH_URL="http://localhost:3000"
